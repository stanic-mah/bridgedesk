HOST=127.0.0.1
PORT=7676
# Owner password generated by `bridgedesk init` in ~/.bridgedesk/auth.json. Set this
# only for non-interactive or fully env-driven deployments.
# BRIDGEDESK_OAUTH_OWNER_TOKEN=change-me-to-a-long-random-secret
# Optional OAuth tuning.
# BRIDGEDESK_OAUTH_ACCESS_TOKEN_TTL_SECONDS=3600
# BRIDGEDESK_OAUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
# BRIDGEDESK_OAUTH_SCOPES=bridgedesk
# BRIDGEDESK_OAUTH_ALLOWED_REDIRECT_HOSTS=chatgpt.com,localhost,127.0.0.1
BRIDGEDESK_ALLOWED_ROOTS=/home/waishnav/personal,/home/waishnav/work
# For temporary tunnels, prefer setting this per run. BridgeDesk derives the
# inbound Host allowlist from this URL.
# BRIDGEDESK_PUBLIC_BASE_URL=https://your-public-host.example.com
# Advanced escape hatch. `*` disables Host header allowlist protection.
# BRIDGEDESK_ALLOWED_HOSTS=localhost,127.0.0.1,your-public-host.example.com
BRIDGEDESK_TOOL_MODE=full
BRIDGEDESK_TOOL_NAMING=legacy
# off | changes | full. Defaults to changes.
# changes creates one aggregate review widget via review_changes instead of per-tool iframes.
BRIDGEDESK_WIDGETS=changes
BRIDGEDESK_LOG_LEVEL=info
BRIDGEDESK_LOG_FORMAT=json
BRIDGEDESK_LOG_REQUESTS=1
BRIDGEDESK_LOG_ASSETS=0
BRIDGEDESK_LOG_TOOL_CALLS=1
BRIDGEDESK_LOG_SHELL_COMMANDS=0
# BRIDGEDESK_TRUST_PROXY=1
# BRIDGEDESK_STATE_DIR=/home/waishnav/.local/share/bridgedesk
# BRIDGEDESK_WORKTREE_ROOT=/home/waishnav/.bridgedesk/worktrees
# BRIDGEDESK_AUTO_LOAD_AGENTS_MD=1
# Skills are enabled by default. Set BRIDGEDESK_SKILLS=0 to hide them.
# BRIDGEDESK_SKILLS=0
# BRIDGEDESK_AGENT_DIR=/home/waishnav/.codex
# BRIDGEDESK_SKILL_PATHS=/home/waishnav/.codex/skills,/home/waishnav/.claude/skills
