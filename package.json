{
  "name": "bridgedesk",
  "version": "1.2.14",
  "description": "Desktop launcher and secure local MCP workspace bridge for ChatGPT and other MCP clients.",
  "type": "module",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20.12 <27"
  },
  "bin": {
    "bridgedesk": "dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "scripts",
    "README.md",
    "RELEASE_NOTES_TEMPLATE.md",
    "UPDATE_LOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build:app": "vite build",
    "build:desktop-assets": "node scripts/copy-desktop-assets.mjs",
    "build": "npm run clean && npm run build:app && tsc -p tsconfig.build.json && npm run build:desktop-assets",
    "dist:win": "npm run build && node scripts/dist-win.mjs",
    "desktop": "npm run build && electron dist/desktop/main.js",
    "dev": "node scripts/dev-server.mjs",
    "release:check": "node scripts/release-check.mjs",
    "release:notes": "node scripts/release-notes.mjs",
    "start": "node dist/cli.js serve",
    "test": "tsx src/config.test.ts && tsx src/oauth-provider.test.ts && tsx src/roots.test.ts && tsx src/pi-tools.test.ts && tsx src/skills.test.ts && tsx src/workspaces.test.ts && tsx src/review-checkpoints.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "mcp",
    "chatgpt",
    "electron",
    "local-workspace",
    "coding-agent"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "@earendil-works/pi-coding-agent": "^0.79.4",
    "@modelcontextprotocol/ext-apps": "^1.7.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@pierre/diffs": "^1.2.5",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.2",
    "electron-updater": "^6.8.9",
    "express": "^5.2.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "semver": "^7.8.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^39.2.7",
    "electron-builder": "^26.15.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  },
  "overrides": {
    "protobufjs": "7.6.4",
    "ws": "8.21.0"
  },
  "electronMain": "dist/desktop/main.js",
  "build": {
    "appId": "com.bridgedesk.app",
    "productName": "BridgeDesk",
    "asar": false,
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "stanic-mah",
        "repo": "bridgedesk"
      }
    ],
    "electronUpdaterCompatibility": ">=2.16",
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json",
      "README.md",
      "UPDATE_LOG.md",
      "LICENSE"
    ],
    "extraMetadata": {
      "main": "dist/desktop/main.js"
    },
    "win": {
      "icon": "build/icon.ico",
      "signExecutable": false,
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "artifactName": "BridgeDesk-Setup.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "BridgeDesk-Portable.${ext}"
    }
  }
}
